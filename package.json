{
  "name": "erp-symb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Native Node.js ERP application for symb",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx src/storage/seed.ts",
    "test": "node tests/run-tests.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fastify": "^5.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
