// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Order {
  id           String   @id @default(cuid())
  orderNumber  String   @unique
  date         DateTime
  deadline     DateTime
  customerId   String
  companyId    String
  managerId    String
  statusId     String
  officeStatusId String
  orderSum     Float    @default(0)
  profitSum    Float    @default(0)
  items        OrderItem[]
  payments     OrderPayment[]
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  productName  String
  quantity     Int
  pricePerUnit Float
  orderSum     Float    @default(0)
  totalCost    Float    @default(0)
  contractor1Id String?
  contractor2Id String?
  contractor1Cost Float @default(0)
  contractor2Cost Float @default(0)
}

model OrderPayment {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  customerId   String
  companyId    String
  amount       Float
  paymentDate  DateTime
  paymentType  PaymentType
}

model Customer {
  id    String @id @default(cuid())
  name  String
  phone String?
}

model CustomerCompany {
  id   String @id @default(cuid())
  name String
}

model Employee {
  id          String @id @default(cuid())
  fullName    String
  position    String
  commissionPercent Float @default(0)
}

model Contractor {
  id   String @id @default(cuid())
  name String
  type ContractorType
}

model OrderStatus {
  id   String @id @default(cuid())
  name String @unique
}

model OfficeStatus {
  id   String @id @default(cuid())
  name String @unique
}

model ProductionStatus {
  id   String @id @default(cuid())
  name String @unique
}

enum PaymentType {
  cash
  card
  bank_transfer
}

enum ContractorType {
  production
  contractor
}